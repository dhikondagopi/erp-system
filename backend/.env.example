# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Supabase PostgreSQL Connection String)
# Format: postgres://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:your-supabase-db-password@db.your-supabase-project-id.supabase.co:5432/postgres

# JWT Secret Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=8h
